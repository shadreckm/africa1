# GEMINI_API_KEY: Required for Gemini AI API calls.
# In Netlify, add this in Site settings > Environment variables.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# In Netlify, this will be your site URL (e.g., https://kulima-africa.netlify.app).
APP_URL="YOUR_NETLIFY_SITE_URL"
